<!-- ═══════════════════════ CONTACT / KALENDER ══════════════ -->
<section class="section contact-section" id="contact">
    <div class="section-container">
        <div class="section-header animate-on-scroll">
            <span class="section-tag">Plan uw afspraak</span>
            <h2>Maak een <span class="accent">Afspraak</span></h2>
            <p>Kies een datum en tijdslot die u uitkomt.</p>
        </div>

        <div class="contact-grid">
            <div class="calendar-wrapper animate-on-scroll">
                <div class="calendar-header">
                    <button class="cal-nav" @onclick="PreviousMonth"><i class="fa-solid fa-chevron-left"></i></button>
                    <h3>@currentMonth.ToString("MMMM yyyy", new System.Globalization.CultureInfo("nl-NL"))</h3>
                    <button class="cal-nav" @onclick="NextMonth"><i class="fa-solid fa-chevron-right"></i></button>
                </div>
                <div class="calendar-weekdays">
                    @foreach (var day in weekdays)
                    {
                        <span>@day</span>
                    }
                </div>
                <div class="calendar-days">
                    @{
                        int startOffset = (int)new DateTime(currentMonth.Year, currentMonth.Month, 1).DayOfWeek;
                        if (startOffset == 0) startOffset = 7;
                        startOffset -= 1;
                    }
                    @for (int e = 0; e < startOffset; e++)
                    {
                        <div class="cal-day empty"></div>
                    }
                    @for (int d = 1; d <= DateTime.DaysInMonth(currentMonth.Year, currentMonth.Month); d++)
                    {
                        var day = d;
                        var date = new DateTime(currentMonth.Year, currentMonth.Month, day);
                        var isToday = date.Date == DateTime.Today;
                        var isPast = date.Date < DateTime.Today;
                        var isSelected = selectedDate?.Date == date.Date;
                        var isWeekend = date.DayOfWeek == DayOfWeek.Saturday || date.DayOfWeek == DayOfWeek.Sunday;
                        <div class="cal-day @(isToday ? "today" : "") @(isPast ? "past" : "") @(isSelected ? "selected" : "") @(isWeekend ? "weekend" : "")"
                             @onclick="() => SelectDate(date, isPast)">
                            @day
                        </div>
                    }
                </div>
                @if (selectedDate.HasValue)
                {
                    <div class="time-slots">
                        <h4><i class="fa-solid fa-clock"></i> Tijdslot voor @selectedDate.Value.ToString("dddd d MMMM", new System.Globalization.CultureInfo("nl-NL"))</h4>
                        <div class="slots-grid">
                            @foreach (var slot in timeSlots)
                            {
                                var s = slot;
                                <button class="time-slot @(selectedSlot == s ? "slot-selected" : "")" @onclick="() => selectedSlot = s">@s</button>
                            }
                        </div>
                    </div>
                }
            </div>

            <div class="contact-form-wrapper animate-on-scroll">
                <div class="contact-info-bar">
                    <div class="contact-info-item">
                        <i class="fa-solid fa-phone"></i>
                        <div><strong>+31 6 12 34 56 78</strong><span>Bereikbaar Ma-Za 08:00-20:00</span></div>
                    </div>
                    <div class="contact-info-item">
                        <i class="fa-solid fa-envelope"></i>
                        <div><strong>info@sjtechniek.nl</strong><span>Reactie binnen 1 uur</span></div>
                    </div>
                    <div class="contact-info-item">
                        <i class="fa-solid fa-location-dot"></i>
                        <div><strong>Amsterdam &amp; omgeving</strong><span>Gratis reiskosten in Amsterdam</span></div>
                    </div>
                </div>

                <form class="contact-form" @onsubmit:preventDefault>
                    <div class="form-row">
                        <div class="form-group">
                            <label>Voornaam *</label>
                            <input type="text" placeholder="Uw voornaam" @bind="contactVoornaam" />
                        </div>
                        <div class="form-group">
                            <label>Achternaam *</label>
                            <input type="text" placeholder="Uw achternaam" @bind="contactAchternaam" />
                        </div>
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label>E-mailadres *</label>
                            <input type="email" placeholder="uw@email.nl" @bind="contactEmail" />
                        </div>
                        <div class="form-group">
                            <label>Telefoonnummer *</label>
                            <input type="tel" placeholder="+31 6 ..." @bind="contactTel" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Dienst</label>
                        <select @bind="contactDienst">
                            <option value="">-- Selecteer dienst --</option>
                            <option>CV Ketel Installatie</option>
                            <option>Jaarlijks Onderhoud</option>
                            <option>Spoedreparatie</option>
                            <option>Radiatoren &amp; Leidingen</option>
                            <option>Vloerverwarming</option>
                            <option>Anders</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Bericht</label>
                        <textarea rows="4" placeholder="Omschrijf uw situatie..." @bind="contactBericht"></textarea>
                    </div>
                    @if (selectedDate.HasValue && !string.IsNullOrEmpty(selectedSlot))
                    {
                        <div class="booking-summary">
                            <i class="fa-solid fa-calendar-check"></i>
                            <span>Afspraak: <strong>@selectedDate.Value.ToString("dddd d MMMM yyyy", new System.Globalization.CultureInfo("nl-NL"))</strong> om <strong>@selectedSlot</strong></span>
                        </div>
                    }
                    <button type="submit" class="btn-primary-custom btn-full" @onclick="SubmitForm">
                        @if (formSent)
                        {
                            <span><i class="fa-solid fa-circle-check"></i> Aanvraag Verzonden!</span>
                        }
                        else
                        {
                            <span><i class="fa-solid fa-paper-plane"></i> Afspraak Aanvragen</span>
                        }
                    </button>
                </form>
            </div>
        </div>
    </div>
</section>

@code {
    private DateTime currentMonth = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);
    private DateTime? selectedDate = null;
    private string? selectedSlot = null;
    private bool formSent = false;

    private string contactVoornaam = "";
    private string contactAchternaam = "";
    private string contactEmail = "";
    private string contactTel = "";
    private string contactDienst = "";
    private string contactBericht = "";

    private string[] weekdays = { "Ma", "Di", "Wo", "Do", "Vr", "Za", "Zo" };

    private string[] timeSlots = {
        "08:00 - 10:00", "10:00 - 12:00", "12:00 - 14:00",
        "14:00 - 16:00", "16:00 - 18:00", "18:00 - 20:00"
    };

    private void PreviousMonth()
    {
        currentMonth = currentMonth.AddMonths(-1);
        selectedDate = null;
        selectedSlot = null;
    }

    private void NextMonth()
    {
        currentMonth = currentMonth.AddMonths(1);
        selectedDate = null;
        selectedSlot = null;
    }

    private void SelectDate(DateTime date, bool isPast)
    {
        if (isPast) return;
        selectedDate = date;
        selectedSlot = null;
    }

    private void SubmitForm()
    {
        if (!string.IsNullOrWhiteSpace(contactVoornaam) && !string.IsNullOrWhiteSpace(contactEmail))
        {
            formSent = true;
        }
    }
}
