    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthState.GetAuthenticationStateAsync();
        if (!authState.User.Identity?.IsAuthenticated == true)
        {
            Nav.NavigateTo("/admin/login", replace: true);
            return;
        }

        var allContent = ContentSvc.GetAll();
        foreach (var section in sections)
        {
            foreach (var field in section.Fields)
            {
                editValues[field.Key] = allContent.TryGetValue(field.Key, out var v) ? v : field.Default;
            }
        }
    }

    private async Task SaveAll()
    {
        isSaving = true;
        foreach (var kv in editValues)
        {
            await ContentSvc.SetAsync(kv.Key, kv.Value);
        }
        isSaving = false;
        savedMessage = true;
        StateHasChanged();
        await Task.Delay(4000);
        savedMessage = false;
        StateHasChanged();
    }
}
