@page "/admin/content"
@rendermode InteractiveServer
@layout AdminLayout
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using SjTechniek.Services
@attribute [Authorize]
@inject ContentService ContentSvc
@inject AuthenticationStateProvider AuthState
@inject NavigationManager Nav

<PageTitle>Inhoud Bewerken – SJ Techniek Admin</PageTitle>

<div class="admin-page">
    <h1 class="admin-page-title">
        <i class="fa-solid fa-pen-to-square"></i> Inhoud Bewerken
        <span class="admin-page-subtitle">Wijzigingen zijn direct zichtbaar op de website</span>
    </h1>

    @if (savedMessage)
    {
        <div class="admin-success">
            <i class="fa-solid fa-circle-check"></i> Opgeslagen! De wijzigingen zijn live op de website.
        </div>
    }

    <div class="admin-content-sections">
        @foreach (var contentSection in sections)
        {
            <div class="admin-content-section">
                <h2 class="admin-section-title">@contentSection.Title</h2>
                <div class="admin-fields-grid">
                    @foreach (var field in contentSection.Fields)
                    {
                        <div class="admin-content-field @(field.Multiline ? "field-wide" : "")">
                            <label>@field.Label</label>
                            @if (field.Multiline)
                            {
                                <textarea @bind="editValues[field.Key]" rows="3" placeholder="@field.Default"></textarea>
                            }
                            else
                            {
                                <input type="text" @bind="editValues[field.Key]" placeholder="@field.Default" />
                            }
                            <div class="admin-field-key">sleutel: <code>@field.Key</code></div>
                        </div>
                    }
                </div>
            </div>
        }
    </div>

    <div class="admin-save-bar">
        <button class="admin-save-btn" @onclick="SaveAll" disabled="@isSaving">
            @if (isSaving)
            {
                <i class="fa-solid fa-spinner fa-spin"></i>
                <span>Opslaan...</span>
            }
            else
            {
                <i class="fa-solid fa-floppy-disk"></i>
                <span>Alle Wijzigingen Opslaan</span>
            }
        </button>
        <a href="/" target="_blank" class="admin-preview-btn">
            <i class="fa-solid fa-eye"></i> Website Bekijken
        </a>
    </div>
</div>

